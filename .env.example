# ===========================================
# RMM System - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# ---------- PostgreSQL ----------
POSTGRES_DB=rmm
POSTGRES_USER=rmm_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ---------- Backend ----------
NODE_ENV=production
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
CORS_ORIGIN=https://your-rmm-domain.com

# ---------- SMTP (Email Alerts) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-rmm-domain.com
ALERT_EMAIL_TO=admin@your-rmm-domain.com

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=https://your-rmm-api-domain.com
NEXT_PUBLIC_WS_URL=wss://your-rmm-api-domain.com

# ---------- Alert Thresholds ----------
ALERT_CPU_THRESHOLD=85
ALERT_RAM_THRESHOLD=90
ALERT_DISK_THRESHOLD=10
ALERT_OFFLINE_MINUTES=2
